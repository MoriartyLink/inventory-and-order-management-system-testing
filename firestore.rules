rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive helpers
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function currentUserData() {
      return getUserData(request.auth.uid);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
             && (currentUserData().role == 'admin' || currentUserData().role == 'owner');
    }

    function isSystemOwner() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
             && currentUserData().role == 'owner';
    }

    // 4. Products
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();

      function isValidProduct(data) {
        return data.keys().hasAll(['name', 'price', 'stock', 'category'])
          && data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.price is number && data.price >= 0
          && data.stock is number && data.stock >= 0
          && data.category is string;
      }
    }

    // 5. Orders
    match /orders/{orderId} {
      allow read: if isSignedIn(); // All staff can see status
      allow create: if isSignedIn() && isValidOrder(request.resource.data) && request.resource.data.createdBy == request.auth.uid;
      
      allow update: if isSignedIn() && (
        // Creator can update their own order
        (resource.data.createdBy == request.auth.uid && isValidOrder(request.resource.data) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['createdBy', 'creatorRole'])) ||
        // Owner can reject an order
        (isSystemOwner() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) && request.resource.data.status == 'rejected')
      );
      
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      function isValidOrder(data) {
        return data.keys().hasAll(['customerName', 'totalAmount', 'status', 'items', 'createdAt', 'createdBy', 'creatorName', 'creatorRole'])
          && data.customerName is string && data.customerName.size() <= 200
          && data.totalAmount is number && data.totalAmount >= 0
          && data.status in ['pending', 'processing', 'shipped', 'delivered', 'cancelled', 'rejected']
          && data.items is list
          && (data.createdAt is timestamp || data.createdAt == request.time)
          && (data.get('updatedBy', '') is string)
          && (data.get('updaterName', '') is string)
          && (data.get('updaterRole', '') is string)
          && (data.get('statusHistory', []) is list);
      }
    }

    // 6. Users
    match /users/{userId} {
      allow read: if request.auth != null && (isOwner(userId) || isAdmin());
      
      // Allow self-creation
      allow create: if isOwner(userId) && (
        (request.resource.data.role == 'owner' && request.auth.token.email == 'moriartylink@gmail.com') ||
        (request.resource.data.role == 'admin')
      ) && isValidUser(request.resource.data);

      allow update: if isAdmin() && (
        (isSystemOwner()) || 
        (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
      );
      allow delete: if isSystemOwner();

      function isValidUser(data) {
        return data.keys().hasAll(['email', 'name', 'role', 'createdAt'])
          && data.email is string && data.email.size() > 0
          && data.name is string && data.name.size() > 0
          && data.role in ['admin', 'owner']
          && (data.createdAt is timestamp || data.createdAt == request.time);
      }
    }
  }
}
